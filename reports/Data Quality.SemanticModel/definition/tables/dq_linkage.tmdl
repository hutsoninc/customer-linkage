table dq_linkage
	lineageTag: 73fb3e64-aca7-43ba-be9a-ebb1cac20af9

	column snapshot_date
		dataType: dateTime
		formatString: General Date
		lineageTag: 28d82061-e0a2-43c2-8194-163fad69a026
		summarizeBy: none
		sourceColumn: snapshot_date

		variation Variation
			isDefault
			relationship: 06f2467f-9f32-465d-b573-1840806ff1ad
			defaultHierarchy: LocalDateTable_1887c173-2178-4b86-9599-6a3d99e5512e.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	column metric_category
		dataType: string
		lineageTag: d25c242e-cc80-45d9-94d6-5bc1e4f85138
		summarizeBy: none
		sourceColumn: metric_category

		annotation SummarizationSetBy = Automatic

	column metric_name
		dataType: string
		lineageTag: 7d673977-28ff-410f-892d-0ed0ef31795d
		summarizeBy: none
		sourceColumn: metric_name

		annotation SummarizationSetBy = Automatic

	column contact_type
		dataType: string
		lineageTag: 5bdd8bc3-b2f9-414a-9f13-cdc26acf5b48
		summarizeBy: none
		sourceColumn: contact_type

