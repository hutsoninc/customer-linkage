table dq_completeness
	lineageTag: b0a41ae6-42c2-437e-8615-5ab202515354

	column snapshot_date
		dataType: dateTime
		formatString: General Date
		lineageTag: c149cba0-4414-42b2-a180-9e2b0a84b96c
		summarizeBy: none
		sourceColumn: snapshot_date

		variation Variation
			isDefault
			relationship: 97062d00-499f-4b2f-a714-193cb9e5e017
			defaultHierarchy: LocalDateTable_b537b5c9-653b-4bd7-bae4-0861c7c3e571.'Date Hierarchy'

