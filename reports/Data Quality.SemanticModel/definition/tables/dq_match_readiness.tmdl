table dq_match_readiness
	lineageTag: 50af6123-b993-4c55-842b-065d7f92f187

	column snapshot_date
		dataType: dateTime
		formatString: General Date
		lineageTag: dac01bb4-416f-4481-b090-17f3ab63a73f
		summarizeBy: none
		sourceColumn: snapshot_date

		variation Variation
			isDefault
			relationship: 9adb4818-ff20-4d33-8afc-d6c9effbafa9
			defaultHierarchy: LocalDateTable_74f0c0fb-7f44-4f88-b414-29e8ac10fd29.'Date Hierarchy'

